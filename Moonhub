    tab5:CreateSection("Auras")
    
    tab5:CreateToggle({
        Name = "Death Aura",
        Default = false,
        Flag = "DeathAura",
        Callback = function(v)
            if v then
                task.spawn(function()
                    while state.running do
                        if not v then break end
                        local hrp = getHRP()
                        if hrp then
                            for _, target in pairs(Players:GetPlayers()) do
                                if target ~= plr then
                                    local char = target.Character
                                    if char then
                                        local tRoot = char:FindFirstChild("HumanoidRootPart")
                                        local tHum = char:FindFirstChild("Humanoid")
                                        if tRoot and tHum and tHum.Health > 0 and (hrp.Position - tRoot.Position).Magnitude <= 29 then
                                            pcall(function()
                                                SetNetworkOwner:FireServer(tRoot, tRoot.CFrame)
                                                DestroyGrabLine:FireServer(tRoot)
                                                tHum.Health = 0
                                            end)
                                        end
                                    end
                                end
                            end
                        end
                        task.wait(0.1)
                    end
                end)
            end
        end
    })

