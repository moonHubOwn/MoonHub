-- // ========== BLOB KILL (ИЗ POLAR) ==========
-- =============================================
local blobKillTask = nil

local function BlobKillFunction(targetName)
    local target = Players:FindFirstChild(targetName)
    if not target then return end
    
    local GE = GrabEvents
    local myChar = plr.Character
    local myHum = myChar and myChar:FindFirstChild("Humanoid")
    if not myHum or not myHum.SeatPart then
        Library:Notify({Title = "Error", Content = "Sit on Blobman first!", Duration = 2})
        return
    end
    
    local myBlob = myHum.SeatPart.Parent
    if not myBlob or myBlob.Name ~= "CreatureBlobman" then
        Library:Notify({Title = "Error", Content = "Not on Blobman!", Duration = 2})
        return
    end
    
    local blobScript = myBlob:FindFirstChild("BlobmanSeatAndOwnerScript")
    if not blobScript then return end
    
    local CG = blobScript:FindFirstChild("CreatureGrab")
    local CR = blobScript:FindFirstChild("CreatureRelease")
    local CD = blobScript:FindFirstChild("CreatureDrop")
    
    if not (CG and CR and CD) then return end
    
    local leftDet = myBlob:FindFirstChild("LeftDetector")
    local rightDet = myBlob:FindFirstChild("RightDetector")
    local leftWeld = leftDet and leftDet:FindFirstChild("LeftWeld")
    local rightWeld = rightDet and rightDet:FindFirstChild("RightWeld")
    
    if not (leftDet and rightDet and leftWeld and rightWeld) then return end
    
    local myHRP = myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return end
    
    while state.blobKill do
        local tChar = target.Character
        if not tChar then
            task.wait(0.5)
            continue
        end
        
        local tRoot = tChar:FindFirstChild("HumanoidRootPart")
        local tHum = tChar:FindFirstChild("Humanoid")
        if not tRoot or not tHum or tHum.Health <= 0 then
            task.wait(0.5)
            continue
        end
        
        local savedPos = myHRP.CFrame
        
        pcall(function()
            myHRP.CFrame = tRoot.CFrame * CFrame.new(0, 0, 2)
            task.wait(0.05)
            
            CG:FireServer(leftDet, tRoot, leftWeld)
            task.wait(0.1)
            CG:FireServer(rightDet, tRoot, rightWeld)
            task.wait(0.1)
            
            tHum.Health = 0
            tHum:ChangeState(Enum.HumanoidStateType.Dead)
            
            CR:FireServer(leftWeld, tRoot)
            CR:FireServer(rightWeld, tRoot)
            
            myHRP.CFrame = savedPos
        end)
        
        task.wait(1)
    end
end

